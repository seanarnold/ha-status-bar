{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HA Status Bar",
  "version": "1.0.0",
  "identifier": "com.hastatusbar.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "HA Status Bar — Settings",
        "width": 620,
        "height": 680,
        "visible": false,
        "closable": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "./Info.plist"
    }
  }
}
